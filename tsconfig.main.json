{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist/main",
    "rootDir": "src",
    "module": "CommonJS",
    "target": "ES2022",
    "lib": ["ES2022"],
    "jsx": "react-jsx",
    "types": ["node", "electron"]
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts"],
  "exclude": ["src/renderer/**"]
}